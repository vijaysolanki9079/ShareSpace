generator client {
  provider  = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// Seed configuration for development data
// Run with: npx prisma db seed
// Read more: https://www.prisma.io/docs/orm/prisma-migrate/workflows/seeding-a-database



model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  fullName  String
  bio       String?
  location  String?
  image     String?
  publicKey String?
  encryptedPrivateKey String?
  keyDerivationSalt String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  donationsDonated Donation[] @relation("DonationDonor")
  requestsMade     Request[]  @relation("RequestRequester")
  
  // Item request system
  itemRequestsMade ItemRequest[]
  itemResponsesGiven ItemResponse[]
  
  // Chat relations
  conversationsAsUser1 Conversation[] @relation("User1Conv")
  conversationsAsUser2 Conversation[] @relation("User2Conv")

  @@index([email])
}

model NGO {
  id                    String     @id @default(cuid())
  email                 String     @unique
  password              String
  organizationName      String
  registrationNumber    String
  website               String?
  missionArea           String
  categories            String[]   @default([])
  verificationDocument  String?
  isVerified            Boolean    @default(false)
  verificationStatus    String     @default("pending") // pending, approved, rejected
  rejectionReason       String?
  bio                   String?
  image                 String?
  knownIssues           String?    // e.g., "Name mismatch in PAN Card", concatenated issues
  latitude              Float?
  longitude             Float?
  locationName          String?
  location_geom         Unsupported("geometry(Point, 4326)")?
  
  // MFA Fields
  mfaSetupComplete      Boolean    @default(false)
  mfaMethod             String?    // 'authenticator' | 'webauthn'
  mfaSecret             String?    // Encrypted TOTP secret
  mfaBackupCodes        String[]   @default([]) // Hashed backup codes (JSON)
  mfaSetupCompletedAt   DateTime?
  isFirstLogin          Boolean    @default(true)
  lastLoginAt           DateTime?
  mfaFailedAttempts     Int        @default(0)
  mfaLockedUntil        DateTime?
  
  // E2EE Chat Fields
  publicKey             String?
  encryptedPrivateKey   String?
  keyDerivationSalt     String?

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  donationsReceived     Donation[]
  eventDrives           EventDrive[]
  verificationDocs      NGOVerificationDocument[]
  mfaAuditLogs          MFAAuditLog[]
  itemRequests          ItemRequest[]
  
  // Chat relations
  conversationsAsNgo1   Conversation[] @relation("NGO1Conv")
  conversationsAsNgo2   Conversation[] @relation("NGO2Conv")

  @@index([email])
  @@index([isVerified])
  @@index([verificationStatus])
}

model NGOVerificationDocument {
  id                String   @id @default(cuid())
  ngoId             String
  ngo               NGO      @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  documentType      String   // "registration_certificate", "pan_card", "darpan_id", "address_proof", 
                             // "bank_account", "kyc_members", "12a_certificate", "80g_certificate", 
                             // "fcra_certificate", "audited_financials", "annual_report", "non_blacklisting"
  fileName          String
  fileUrl           String   // URL to Supabase Storage or Cloudinary
  uploadedAt        DateTime @default(now())
  status            String   @default("pending") // pending, verified, rejected
  verificationNote  String?  // Admin notes during verification

  @@index([ngoId])
  @@index([documentType])
  @@index([status])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Donation {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  image       String?
  status      String   @default("pending")
  donorId     String
  donor       User     @relation(fields: [donorId], references: [id], name: "DonationDonor", onDelete: Cascade)
  ngoId       String?
  ngo         NGO?     @relation(fields: [ngoId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests    Request[]

  @@index([donorId])
  @@index([ngoId])
  @@index([status])
  @@index([category])
}

model Request {
  id          String   @id @default(cuid())
  donationId  String
  donation    Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User     @relation(fields: [requesterId], references: [id], name: "RequestRequester", onDelete: Cascade)
  status      String   @default("open")
  createdAt   DateTime @default(now())

  @@index([donationId])
  @@index([requesterId])
  @@index([status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId       String
  senderType     String       // 'USER' or 'NGO'
  
  content        String       // Encrypted cipher text OR plain text if isSystem is true
  isSystem       Boolean      @default(false)
  
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
}

model EventDrive {
  id          String   @id @default(cuid())
  title       String
  description String?
  ngoId       String
  ngo         NGO      @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  date        DateTime
  location    String?
  createdAt   DateTime @default(now())

  @@index([ngoId])
  @@index([date])
}

model MFAAuditLog {
  id        String   @id @default(cuid())
  ngoId     String
  ngo       NGO      @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  action    String   // 'setup', 'verify', 'failed_verify', 'backup_code_used', 'setup_complete', 'failed_verify_login', 'verify_login'
  success   Boolean
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([ngoId])
  @@index([action])
  @@index([createdAt])
}

// ====== ITEM REQUEST SYSTEM (P2P & NGO) ======

model ItemCategory {
  id          String        @id @default(cuid())
  name        String        @unique // 'furniture', 'clothes', 'toys', 'tools', 'electronics', etc.
  description String?
  icon        String?
  createdAt   DateTime      @default(now())

  itemRequests ItemRequest[]

  @@index([name])
}

model ItemRequest {
  id            String        @id @default(cuid())
  
  // Requester (user who needs the item)
  requesterId   String
  requester     User          @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  
  // Request details
  title         String        // e.g., "Need a bed frame"
  description   String
  categoryId    String
  category      ItemCategory  @relation(fields: [categoryId], references: [id])
  
  // Images (array of URLs from Supabase Storage)
  images        String[]      @default([])
  
  // Location (PostGIS: store as point in database)
  latitude      Float
  longitude     Float
  locationName  String?       // e.g., "Delhi, 500m radius"
  radius        Int           @default(5000) // Search radius in meters (default 5km)
  location_geom Unsupported("geometry(Point, 4326)")?
  
  // Status tracking
  status        String        @default("open") // 'open', 'fulfilled', 'closed'
  
  // Optional: link to NGO if posted through NGO dashboard
  ngoId         String?
  ngo           NGO?          @relation(fields: [ngoId], references: [id], onDelete: SetNull)
  
  // Responses from donors
  responses     ItemResponse[]
  
  // Chat conversations
  conversations Conversation[]  @relation("ItemRequestConv")
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([requesterId])
  @@index([categoryId])
  @@index([status])
  @@index([ngoId])
  @@index([createdAt])
}

model ItemResponse {
  id            String        @id @default(cuid())
  
  // Response from donor
  donorId       String
  donor         User          @relation(fields: [donorId], references: [id], onDelete: Cascade)
  
  // To which request
  itemRequestId String
  itemRequest   ItemRequest   @relation(fields: [itemRequestId], references: [id], onDelete: Cascade)
  
  // Active conversation for this response
  conversationId String?
  conversation   Conversation? @relation("ItemResponseConv", fields: [conversationId], references: [id], onDelete: SetNull)
  
  // Status: is donor still interested, did they fulfil it, etc.
  status        String        @default("interested") // 'interested', 'fulfilled', 'no_longer_interested'
  
  message       String?       // Initial message from donor
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([donorId, itemRequestId])
  @@index([donorId])
  @@index([itemRequestId])
  @@index([status])
}

// Extended Conversation for item requests
model Conversation {
  id        String   @id @default(cuid())
  
  // Participants (Flexible to allow User-User, User-NGO, or NGO-NGO)
  user1Id   String?
  user1     User?    @relation("User1Conv", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String?
  user2     User?    @relation("User2Conv", fields: [user2Id], references: [id], onDelete: Cascade)
  
  ngo1Id    String?
  ngo1      NGO?     @relation("NGO1Conv", fields: [ngo1Id], references: [id], onDelete: Cascade)
  ngo2Id    String?
  ngo2      NGO?     @relation("NGO2Conv", fields: [ngo2Id], references: [id], onDelete: Cascade)
  
  // Item request related chat
  itemRequestId String?
  itemRequest   ItemRequest? @relation("ItemRequestConv", fields: [itemRequestId], references: [id], onDelete: Cascade)
  
  itemResponses ItemResponse[] @relation("ItemResponseConv")
  
  messages  Message[]
  
  status    String   @default("PENDING") // 'PENDING', 'ACCEPTED', 'REJECTED'
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([user1Id])
  @@index([user2Id])
  @@index([ngo1Id])
  @@index([ngo2Id])
  @@index([itemRequestId])
}
